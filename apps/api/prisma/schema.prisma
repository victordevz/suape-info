  @@index([licenseId])
  @@index([regulatoryClauseId])
  @@index([responsiblePartyId])
  @@index([type])
  @@index([status])
  @@map("authorized_resources")
}

model RiskSignal {
  id                 String            @id @default(uuid()) @db.Uuid
  kind               RiskKind
  severity           RiskSeverity
  reason             String
  status             RecordStatus      @default(ACTIVE)
  licenseId          String?           @db.Uuid
  regulatoryClauseId String?           @db.Uuid
  obligationId       String?           @db.Uuid
  deadlineId         String?           @db.Uuid
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  resolvedAt         DateTime?
  license            License?          @relation(fields: [licenseId], references: [id])
  regulatoryClause   RegulatoryClause? @relation(fields: [regulatoryClauseId], references: [id])
  obligation         Obligation?       @relation(fields: [obligationId], references: [id])
  deadline           Deadline?         @relation(fields: [deadlineId], references: [id])

  @@index([kind])
  @@index([severity])
  @@index([status])
  @@index([regulatoryClauseId])
  @@map("risk_signals")
}

model AuditEvent {
  id            String      @id @default(uuid()) @db.Uuid
  actorUserId   String?     @db.Uuid
  action        AuditAction
  resource      String
  resourceId    String?
  previousData  Json?
  newData       Json?
  reason        String?
  sourceIp      String?
  correlationId String?
  createdAt     DateTime    @default(now())
  actorUser     User?       @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_events")
}

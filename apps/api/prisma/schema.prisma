  @@unique([infractionNumber])
  @@index([linkedLicenseId])
  @@index([linkedRegulatoryClauseId])
  @@index([status])
  @@map("infraction_cases")
}

model AuthorizedResource {
  id                 String                 @id @default(uuid()) @db.Uuid
  licenseId          String                 @db.Uuid
  regulatoryClauseId String?                @db.Uuid
  responsiblePartyId String?                @db.Uuid
  type               AuthorizedResourceType
  name               String
  identifier         String?
  professionalRecord String?
  roleDescription    String?
  quantity           Decimal?               @db.Decimal(10, 2)
  notes              String?
  status             RecordStatus           @default(ACTIVE)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?
  license            License                @relation(fields: [licenseId], references: [id])
  regulatoryClause   RegulatoryClause?      @relation(fields: [regulatoryClauseId], references: [id])

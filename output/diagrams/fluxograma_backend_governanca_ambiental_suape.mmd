flowchart LR
  subgraph FONTES["Fontes de dados mantidas pelo time"]
    DRIVE["Google Drive<br/>Docs, PDFs, fotos, mapas, ARTs, oficios"]
    SHEETS["Google Sheets<br/>prazos, responsaveis, status, controles"]
    GOV["Sistemas externos<br/>Governo PE, orgaos ambientais, bombeiros, prefeituras"]
    UPLOAD["Upload eventual<br/>arquivos historicos e complementares"]
    CRUD["CRUD manual<br/>ajustes, cadastros e excecoes"]
  end

  subgraph INGESTAO["Camada de ingestao e sincronizacao"]
    GOOGLE_API["Conectores Google API<br/>OAuth, Drive API, Sheets API"]
    WATCHER["Monitor de mudancas<br/>webhook, polling e jobs agendados"]
    IMPORT_QUEUE["Fila de importacao<br/>idempotencia, checksum, retry"]
    SOURCE_REGISTRY["Registro da origem<br/>fonte, arquivo, planilha, aba, linha, versao"]
  end

  subgraph PROCESSAMENTO["Processamento e organizacao da informacao"]
    EXTRACT["Extracao de conteudo<br/>texto, OCR, metadados, tabelas"]
    NORMALIZE["Normalizacao<br/>preserva original e gera versao consultavel"]
    AI_CLASSIFIER["IA assistiva de classificacao<br/>sugere obra, licenca, condicionante, obrigacao, prazo"]
    VALIDATION["Validacao humana<br/>area responsavel ou aprovador tecnico confirma vinculos"]
  end

  subgraph STORAGE["Armazenamento governado"]
    OBJECT_STORE["Object Storage versionado<br/>originais, anexos, comprovantes, evidencias"]
    REL_DB["Banco relacional transacional<br/>modelo regulatorio e trilha operacional"]
    SEARCH_INDEX["Indice de busca<br/>consulta textual e filtros estruturados"]
    VECTOR_INDEX["Indice vetorial<br/>RAG com trechos e referencias aos documentos"]
    AUDIT_LEDGER["Trilha de auditoria imutavel<br/>criacao, edicao, exclusao logica, download, envio, aprovacao"]
  end

  subgraph MODELO["Modelo central de dados"]
    OBRA["Obra ou atividade"]
    LICENCA["Licenca ou autorizacao<br/>vigencia, renovacao, orgao, escopo"]
    COND["Condicionante<br/>periodicidade, prazo, status"]
    OBRIG["Obrigacao regulatoria<br/>entrega concreta e rastreavel"]
    EVID["Evidencia<br/>arquivo, tipo, origem, validade, confidencialidade"]
    PROTO["Protocolo ou envio<br/>numero, orgao, sistema, comprovante"]
    RESP["Responsavel<br/>pessoa, area, contratada, aprovador"]
    EVENTO["Evento auditavel<br/>usuario, acao, dado anterior, dado novo, justificativa"]
  end

  subgraph SERVICOS["Servicos de backend"]
    API["API da aplicacao<br/>RBAC/ABAC, LGPD, permissoes por perfil e area"]
    CRUD_SERVICE["Servicos CRUD<br/>cadastro regulatorio, matriz de responsabilidade, status"]
    SCHEDULER["Agenda preditiva<br/>vencimentos, recorrencias, renovacoes, SLA"]
    RISK["Motor de risco<br/>prazos proximos, evidencias faltantes, protocolos sem comprovante"]
    DOSSIER["Gerador de dossie<br/>obra, licenca, condicionante, processo, orgao"]
    EXPORT["Exportacao controlada<br/>auditoria, fiscalizacao, defesas e relatorios gerenciais"]
  end

  subgraph IA["Microservico de IA seguro"]
    RAG["RAG corporativo<br/>busca hibrida em banco, indice textual e indice vetorial"]
    AI_TOOLS["Ferramentas controladas<br/>SQL somente leitura, recuperacao de evidencias, resumo de processos"]
    AI_GUARD["Governanca da IA<br/>permissoes, citacoes, logs, mascaramento, sem escrita automatica"]
    AI_ASSIST["Assistente de navegacao<br/>perguntas, prazos, status, riscos, documentos relacionados"]
  end

  subgraph APP["Aplicacao de consulta e operacao"]
    UI_SEARCH["Busca e navegacao<br/>por obra, licenca, orgao, condicionante, prazo, status"]
    UI_PROCESS["Tela do processo<br/>linha do tempo, evidencias, protocolos, decisoes"]
    UI_ALERTS["Painel de riscos<br/>pendencias, vencimentos, atrasos, responsaveis"]
    UI_AUDIT["Auditoria e historico<br/>quem fez, quando, por que e qual versao"]
  end

